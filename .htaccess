# 1. Disable MultiViews (Crucial for clean URLs)
Options -MultiViews -Indexes

# 2. Custom Error Page
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ==========================================
    # 1. FORCE HTTPS
    # ==========================================
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ==========================================
    # 2. EXTERNAL REDIRECTS (Clean the URL Bar)
    # ==========================================
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^in/([^/.]+)\.html$ /$1 [R=301,L]
    
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^in/([^/.]+)$ /$1 [R=301,L]

    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^([^/.]+)\.html$ /$1 [R=301,L]

    # ==========================================
    # 3. INTERNAL ROUTING (Serve from /in/ safely)
    # ==========================================
    # Ignore existing folders and files
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    # Safely route the clean URL to the /in/ folder without crashing
    RewriteRule ^([^/]+)/?$ in/$1.html [L]
</IfModule>
