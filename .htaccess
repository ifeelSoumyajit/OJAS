# 1. Disable MultiViews (Prevents server from fighting clean URLs)
Options -MultiViews -Indexes

# 2. Set custom 404 page
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 3. EXTERNAL REDIRECT: Strip .html AND hide the /in/ folder from the URL bar
    # If someone types /about.html or /in/about.html, force it to just /about
    RewriteCond %{THE_REQUEST} \s/+(?:in/)?([^/.\s]+)\.html [NC,OR]
    RewriteCond %{THE_REQUEST} \s/+in/([^/.\s]+) [NC]
    RewriteRule ^ /%1 [R=301,L]

    # 4. INTERNAL ROUTING: Secretly fetch the .html file from the /in/ folder
    # If it's not a real folder and not a real file in the root...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    # ...then serve the .html file from the /in/ folder behind the scenes.
    RewriteRule ^([^/]+)/?$ in/$1.html [L]
</IfModule>
