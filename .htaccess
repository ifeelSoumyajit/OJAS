# 1. Disable MultiViews (Prevents server confusion)
Options -MultiViews -Indexes

# 2. Custom Error Page
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # ---------------------------------------------------------
    # FORCE HTTPS
    # ---------------------------------------------------------
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ---------------------------------------------------------
    # EXTERNAL REDIRECTS (Forces the URL bar to change)
    # ---------------------------------------------------------
    # Rule A: If user visits /in/vision.html or /in/vision -> Redirect to /vision
    RewriteCond %{THE_REQUEST} \s/+in/([^/.\s]+) [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Rule B: If user visits /vision.html -> Redirect to /vision
    RewriteCond %{THE_REQUEST} \s/+([^/.\s]+)\.html [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # ---------------------------------------------------------
    # INTERNAL ROUTING (Secretly load the file)
    # ---------------------------------------------------------
    # If the request is NOT a real folder (/public/, /styles/)...
    RewriteCond %{REQUEST_FILENAME} !-d
    # And is NOT a real file (index.html, sitemap.xml)...
    RewriteCond %{REQUEST_FILENAME} !-f
    # Safely route the clean name to the /in/ folder!
    RewriteRule ^([^/]+)/?$ /in/$1.html [L]
</IfModule>
