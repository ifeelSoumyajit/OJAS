# 1. Disable MultiViews (Crucial for clean URLs to work)
Options -MultiViews -Indexes

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 2. EXTERNAL REDIRECT: Force the browser to remove .html
    # If the browser requests /about.html or /in/about.html, redirect to /about
    RewriteCond %{THE_REQUEST} \s/+(?:in/)?([^/.]+)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # 3. INTERNAL ROUTING: Connect the clean URL to the actual file
    # If it's not a folder and not an existing file, serve the .html from /in/
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^([^/]+)/?$ in/$1.html [L]
</IfModule>
